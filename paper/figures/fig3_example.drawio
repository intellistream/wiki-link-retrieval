        </mxCell>
        <mxCell id="legend_bm25" value="BM25 retrieved" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=9;" vertex="1" parent="1">

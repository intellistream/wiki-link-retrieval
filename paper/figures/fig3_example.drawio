<mxfile host="app.diagrams.net" modified="2026-06-21" agent="drawio" version="24.0.0" type="device">
  <diagram name="Worked Example" id="fig-example">
    <mxGraphModel dx="600" dy="400" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="600" pageHeight="350" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <!-- Identity (film) - retrieved by BM25 (blue) -->
        <mxCell id="identity" value="Identity (film)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="40" y="120" width="160" height="50" as="geometry"/>
        </mxCell>

        <!-- James Mangold - gold answer (green) -->
        <mxCell id="mangold" value="James Mangold" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="320" y="60" width="160" height="50" as="geometry"/>
        </mxCell>

        <!-- Cop Land - linked from Mangold (blue) -->
        <mxCell id="copland" value="Cop Land" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="420" y="200" width="140" height="50" as="geometry"/>
        </mxCell>

        <!-- John Cusack - cast member (blue) -->
        <mxCell id="cusack" value="John Cusack" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="40" y="260" width="140" height="50" as="geometry"/>
        </mxCell>

        <!-- Edge: Identity -> Mangold (director) -->
        <mxCell id="e_dir" value="director" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeWidth=2;endArrow=blockThin;endFill=1;strokeColor=#82b366;fontStyle=2;fontSize=10;fontColor=#82b366;labelBackgroundColor=#ffffff;" edge="1" source="identity" target="mangold" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Edge: Mangold -> Cop Land (filmography) -->
        <mxCell id="e_film" value="filmography" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeWidth=1.5;endArrow=blockThin;endFill=1;strokeColor=#6c8ebf;fontStyle=2;fontSize=10;fontColor=#6c8ebf;labelBackgroundColor=#ffffff;" edge="1" source="mangold" target="copland" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Edge: Identity -> Cusack (cast) -->
        <mxCell id="e_cast" value="cast" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeWidth=1.5;endArrow=blockThin;endFill=1;strokeColor=#6c8ebf;fontStyle=2;fontSize=10;fontColor=#6c8ebf;labelBackgroundColor=#ffffff;" edge="1" source="identity" target="cusack" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Legend -->
        <mxCell id="legend_title" value="&lt;b&gt;Legend&lt;/b&gt;" style="text;html=1;align=left;fontSize=10;" vertex="1" parent="1">
